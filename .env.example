# patan Configuration
# Copy this file to .env and fill in your values

# ========== Required ==========

# Your authentication cookie (get from browser DevTools)
COOKIE=""

# ========== Optional ==========

# Proxy settings (if needed)
# HTTP_PROXY="http://127.0.0.1:7890"
# HTTPS_PROXY="http://127.0.0.1:7890"

# Custom User-Agent
# Default: Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/90.0.4430.212 Safari/537.36
# USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"

# Advanced token settings (usually not needed to change)
# MS_TOKEN_URL="https://mssdk.bytedance.com/web/report"
# MS_TOKEN_MAGIC="538969122"
# MS_TOKEN_VERSION="1"
# MS_TOKEN_DATATYPE="8"
# MS_TOKEN_STRDATA=""
# MS_TOKEN_USER_AGENT="5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"

# TTWID settings
# TTWID_URL="https://ttwid.bytedance.com/ttwid/union/register/"
# TTWID_DATA='{"region":"cn","aid":1768,"needFid":false,"service":"www.ixigua.com","migrate_info":{"ticket":"","source":"node"},"cbUrlProtocol":"https","union":true}'
